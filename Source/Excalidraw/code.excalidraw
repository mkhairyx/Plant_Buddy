      "boundElements": [],
      "updated": 1781765903936,
      "link": null,
      "locked": false,
      "text": "while running water, check if flow\nsensor is sending signals. if not,\nhalt everything until the user sends\na restart message (after refilling\nthe water), other words: go into\nloop and do not leave unless a\nmessage is recieved",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "fYUMr29vQo13jCEP2foTN",
      "originalText": "while running water, check if flow sensor is sending signals. if not, halt everything until the user sends a restart message (after refilling the water), other words: go into loop and do not leave unless a message is recieved",
      "autoResize": true,
      "lineHeight": 1.25
    },
