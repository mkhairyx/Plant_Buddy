    {
      "id": "KSr7Bz449OOomxmxXxGEw",
      "type": "text",
      "x": 1502.318323328917,
      "y": 156.60542762973057,
      "width": 602.5595703125,
      "height": 225,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b7MV",
      "roundness": null,
      "seed": 1069053091,
      "version": 735,
      "versionNonce": 786936035,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1781826638937,
      "link": null,
      "locked": false,
      "text": "Each \"periodic time\" days, water the plant with the specified\namount of water in litres. (put the esp32 into deep sleep and\ndo not wake it up unless the 5 days timer is over, or a\nmessage is recieved which wakes it up for 10 mins then goes\nback to sleep)\nEach 5 days send moisture and bat level to user\nsleep 10 mins after waking up for the task.\nAfter finishing the cycle with a periodic time, restart the\nesp32 without notifying the user (esp.restart function)",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "KgPbu6XCrACS0gV35q91N",
      "originalText": "Each \"periodic time\" days, water the plant with the specified amount of water in litres. (put the esp32 into deep sleep and do not wake it up unless the 5 days timer is over, or a message is recieved which wakes it up for 10 mins then goes back to sleep)\nEach 5 days send moisture and bat level to user\nsleep 10 mins after waking up for the task.\nAfter finishing the cycle with a periodic time, restart the esp32 without notifying the user (esp.restart function)",
      "autoResize": true,
      "lineHeight": 1.25
    },
