      "updated": 1781765454726,
      "link": null,
      "locked": false,
      "text": "If user ask for the status, send\nthe following (causing an\ninterupt):\nBat level\nSoil moisture\ndays left and days since last\nwatering.\nperiodic time\nlitres to pour\nwater status\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "t3E0ChTIvE6_d0__UZqjo",
      "originalText": "If user ask for the status, send the following (causing an interupt):\nBat level\nSoil moisture\ndays left and days since last watering.\nperiodic time\nlitres to pour\nwater status\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
