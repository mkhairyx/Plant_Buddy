      "boundElements": null,
      "updated": 1781765932396,
      "link": null,
      "locked": false,
      "text": "Each 30 days, water the plant with the specified amount of\nwater in litres. (put the esp32 into deep sleep and do not\nwake it up unless the 5 days timer is over, or a message is\nrecieved which wakes it up for 10 mins then goes back to\nsleep)\nEach 5 days send moisture and bat level to user",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "KgPbu6XCrACS0gV35q91N",
      "originalText": "Each 30 days, water the plant with the specified amount of water in litres. (put the esp32 into deep sleep and do not wake it up unless the 5 days timer is over, or a message is recieved which wakes it up for 10 mins then goes back to sleep)\nEach 5 days send moisture and bat level to user",
      "autoResize": true,
      "lineHeight": 1.25
    },
